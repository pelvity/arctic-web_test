{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Run All (Hybrid: Docker DB + Local Code)",
            "dependsOn": [
                "Start MongoDB (Docker)",
                "Run App (Local)"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "🐳 Run All (Full Docker)",
            "type": "shell",
            "command": "npm run dev:docker",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "💻 Run All (Fully Local)",
            "dependsOn": [
                "Backend (Local)",
                "Frontend (Local)"
            ],
            "problemMatcher": []
        },
        {
            "label": "Run App (Local)",
            "type": "shell",
            "command": "npm run dev:local",
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Start MongoDB (Docker)",
            "type": "shell",
            "command": "npm run db:up",
            "problemMatcher": []
        },
        {
            "label": "Stop Docker Services",
            "type": "shell",
            "command": "npm run db:down",
            "problemMatcher": []
        },
        {
            "label": "Backend (Local)",
            "type": "shell",
            "command": "npm run start:dev",
            "options": {
                "cwd": "${workspaceFolder}/backend"
            },
            "isBackground": true,
            "problemMatcher": [
                "$tsc-watch"
            ]
        },
        {
            "label": "Frontend (Local)",
            "type": "shell",
            "command": "npm run dev",
            "options": {
                "cwd": "${workspaceFolder}/frontend"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "🧪 Run Tests (Backend Unit)",
            "type": "shell",
            "command": "npm test -w backend",
            "group": "test",
            "problemMatcher": [
                "$tsc"
            ]
        },
        {
            "label": "🧪 Run Tests (Backend E2E)",
            "type": "shell",
            "command": "npm run test:e2e -w backend",
            "group": "test",
            "problemMatcher": [
                "$tsc"
            ]
        }
    ]
}